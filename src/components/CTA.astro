---
// Final CTA Section
---

<section id="contact" class="section-pad cta-section section-light">
  <div class="container-znatic">

    <div class="cta-body reveal">
      <div class="cta-left">
        <span class="eyebrow">Start a Project</span>
        <h2 class="cta-headline">
          Ready to build<br />
          something <em class="cta-em">remarkable?</em>
        </h2>
      </div>
      <div class="cta-right">
        <p class="cta-desc">
          Tell us about your vision and let's figure out how
          we can help bring it to life together.
        </p>
        <form class="cta-form" id="cta-form" novalidate>
          <div class="form-field">
            <label for="f-name">Name</label>
            <input id="f-name" name="name" type="text" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="f-project">Project Brief</label>
            <textarea id="f-project" name="project" rows="4" placeholder="Tell us about your project..." required></textarea>
          </div>
          <div class="form-footer">
            <button type="submit" class="btn-gold cta-btn">
              Send Message
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <span class="form-alt">or <a href="mailto:studio@znatic.my.id">studio@znatic.my.id</a></span>
          </div>
        </form>
        <div class="form-sent" id="form-sent">
          <p class="form-sent-msg"><span id="sent-typed"></span><span class="sent-cursor">|</span></p>
          <button class="form-sent-back" id="form-sent-back">Wanna contact more? →</button>
        </div>
      </div>
    </div>

    <div class="cta-details reveal">
      <div class="cta-details-header">
        <span class="cta-avail-dot"></span>
        <span class="cta-avail-label">Currently accepting projects</span>
      </div>

      <div class="cta-row cta-row--link" id="copy-email-row">
        <div class="cta-row-left">
          <svg class="cta-row-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 8l10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="cta-row-label">Email</span>
        </div>
        <div class="cta-row-right">
          <span class="cta-row-val cta-copy-val" id="copy-email-val">studio@znatic.my.id</span>
          <span class="cta-copy-hint" id="copy-email-hint">Copy</span>
          <svg class="cta-row-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>

      <div class="cta-row cta-row--link">
        <div class="cta-row-left">
          <svg class="cta-row-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12c0 1.85.5 3.58 1.38 5.06L2 22l5.06-1.34A9.94 9.94 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.5 10.2c.1-.4.4-.9.7-1 .3-.1.5 0 .7.3l.6 1.3c.1.3 0 .5-.2.7l-.3.3c.4.7 1 1.3 1.7 1.7l.3-.3c.2-.2.4-.3.7-.2l1.3.6c.3.2.4.4.3.7-.1.3-.6.6-1 .7C12.1 15.8 9.3 13 9.5 10.2z" fill="currentColor"/></svg>
          <span class="cta-row-label">WhatsApp</span>
        </div>
        <div class="cta-row-right">
          <a href="https://wa.me/6282220572148" target="_blank" rel="noopener" class="cta-row-val cta-link">+62 822-2057-2148</a>
          <svg class="cta-row-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>

      <div class="cta-row cta-row--link">
        <div class="cta-row-left">
          <svg class="cta-row-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="0.75" fill="currentColor"/></svg>
          <span class="cta-row-label">Instagram</span>
        </div>
        <div class="cta-row-right">
          <a href="https://instagram.com/znatic.id" target="_blank" rel="noopener" class="cta-row-val cta-link">@znatic.id</a>
          <svg class="cta-row-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>

      <div class="cta-row cta-row--info">
        <div class="cta-info-cell">
          <div class="cta-row-left">
            <svg class="cta-row-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            <span class="cta-row-label">Location</span>
          </div>
          <span class="cta-row-val">Remote — Worldwide</span>
        </div>
        <div class="cta-info-sep"></div>
        <div class="cta-info-cell">
          <div class="cta-row-left">
            <svg class="cta-row-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M2 12h20M12 2c-2.5 3-4 6.5-4 10s1.5 7 4 10M12 2c2.5 3 4 6.5 4 10s-1.5 7-4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span class="cta-row-label">Languages</span>
          </div>
          <span class="cta-row-val">EN · ID</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .cta-section {
    overflow: hidden;
  }

  /* Two-column body */
  .cta-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    margin-bottom: 48px;
  }

  @media (max-width: 900px) {
    .cta-body { grid-template-columns: 1fr; gap: 32px; margin-bottom: 48px; }
  }

  @media (max-width: 580px) {
    .cta-body { gap: 24px; margin-bottom: 36px; }
    .cta-headline { margin-top: 8px; }
  }

  /* Left column */
  .cta-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-top: 20px;
  }

  .cta-em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold);
  }

  /* Right column */
  .cta-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.78;
    max-width: 46ch;
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .cta-btn {
    font-size: 0.875rem;
    padding: 14px 28px;
  }

  .cta-note {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cta-note span {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Contact Form */
  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .form-field input,
  .form-field textarea {
    background: transparent;
    border: 1px solid var(--color-border-soft);
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 0.9rem;
    color: var(--color-text-primary);
    font-family: inherit;
    outline: none;
    resize: none;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .section-light .form-field input,
  .section-light .form-field textarea {
    border-color: #D0D0D0;
    color: #000;
  }

  .section-light .form-field input::placeholder,
  .section-light .form-field textarea::placeholder {
    color: #A0A0A0;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: #000;
  }

  .section-dark .form-field input:focus,
  .section-dark .form-field textarea:focus {
    border-color: #FFF;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .form-alt {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .form-alt a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Sent / success state */
  .form-sent {
    display: none;
    flex-direction: column;
    gap: 28px;
  }

  .form-sent-msg {
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    margin: 0;
    min-height: 2.8em;
  }

  .sent-cursor {
    display: inline-block;
    opacity: 1;
    animation: caret-blink 0.9s step-end infinite;
    font-weight: 300;
    color: var(--color-text-muted);
    margin-left: 1px;
  }

  @keyframes caret-blink {
    50% { opacity: 0; }
  }

  .form-sent-back {
    display: none;
    background: none;
    border: 1px solid #C0C0C0;
    border-radius: 20px;
    font-family: inherit;
    font-size: 0.8rem;
    color: #444;
    cursor: pointer;
    padding: 6px 16px;
    align-self: flex-start;
    letter-spacing: 0.02em;
    transition: border-color 0.2s, color 0.2s;
  }

  .form-sent-back:hover {
    border-color: #000;
    color: #000;
  }

  /* Detail rows */
  .cta-details {
    display: flex;
    flex-direction: column;
  }

  .cta-details-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 18px 0 14px;
  }

  .cta-avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 2px rgba(34,197,94,0.25);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 2px rgba(34,197,94,0.25); }
    50% { box-shadow: 0 0 0 5px rgba(34,197,94,0.1); }
  }

  .cta-avail-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #22c55e;
  }

  .cta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .cta-row--link {
    cursor: pointer;
    transition: padding-left 0.25s var(--ease-apple);
  }

  .cta-row--link:hover {
    padding-left: 6px;
  }

  .cta-row--link:hover .cta-row-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .cta-row-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cta-row-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cta-row-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
    opacity: 0.6;
  }

  .cta-row-arrow {
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .cta-row-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cta-row-val {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Copy email */
  .cta-copy-val {
    cursor: pointer;
  }

  .cta-copy-hint {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.2s;
    padding: 2px 7px;
    border: 1px solid var(--color-border-soft);
    border-radius: 4px;
  }

  #copy-email-row:hover .cta-copy-hint {
    opacity: 1;
  }

  .cta-copy-hint.copied {
    color: #22c55e;
    border-color: rgba(34,197,94,0.3);
    opacity: 1 !important;
  }

  .cta-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta-link:hover { color: var(--color-text-primary); }

  /* 2-col info row */
  .cta-row--info {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 0;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .cta-info-cell {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cta-info-cell .cta-row-val {
    padding-left: 24px;
  }

  .cta-info-sep {
    width: 1px;
    background: var(--color-border-soft);
    align-self: stretch;
    margin: 0 24px;
  }

  @media (max-width: 480px) {
    .cta-row--info { grid-template-columns: 1fr; gap: 16px; }
    .cta-info-sep { display: none; }
    .cta-info-cell .cta-row-val { padding-left: 24px; }

    /* Tighten rows on mobile */
    .cta-row,
    .cta-row--info {
      padding: 14px 0;
    }

    .cta-row-label {
      font-size: 0.65rem;
      letter-spacing: 0.08em;
    }

    .cta-row-val,
    .cta-link {
      font-size: 0.8rem;
      word-break: break-all;
    }

    /* Hide hover-only elements on touch */
    .cta-row-arrow {
      display: none;
    }

    .cta-copy-hint {
      display: none;
    }

    .cta-row-right {
      min-width: 0;
      max-width: 55%;
      justify-content: flex-end;
    }

    /* Smaller typing text on mobile */
    .form-sent-msg {
      font-size: 1.2rem;
      min-height: auto;
    }

    .cta-details-header {
      padding: 12px 0 10px;
    }

    .cta-avail-label {
      font-size: 0.65rem;
    }
  }
</style>

<script is:inline>
(function() {
  var form      = document.getElementById('cta-form');
  var sentBox   = document.getElementById('form-sent');
  var sentTyped = document.getElementById('sent-typed');
  var sentBack  = document.getElementById('form-sent-back');
  if (!form || !sentBox) return;

  var phrases = [
    'Thank you for reaching out to ZNATIC.\nWe\'ll be in touch shortly.',
    'Your message is on its way.\nWe appreciate you choosing ZNATIC.',
    'Great things are coming.\nWe\'ll get back to you soon.'
  ];

  var cycleTimer = null;
  var phraseIndex = 0;
  var firstPhraseShown = false;

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var nameEl    = document.getElementById('f-name');
    var projectEl = document.getElementById('f-project');
    var name    = nameEl.value.trim();
    var project = projectEl.value.trim();

    var ok = true;
    [nameEl, projectEl].forEach(function(el) {
      if (!el.value.trim()) {
        el.style.borderColor = '#ef4444';
        setTimeout(function() { el.style.borderColor = ''; }, 1600);
        ok = false;
      }
    });
    if (!ok) return;

    var msg = [
      '*New Project Inquiry \u2014 ZNATIC*',
      '',
      '*Name:* ' + name,
      '',
      '*Project Brief:*',
      project,
      '',
      '_Sent via znatic.id_'
    ].join('\n');

    var waUrl = 'https://wa.me/6282220572148?text=' + encodeURIComponent(msg);

    form.style.transition = 'opacity 0.3s ease';
    form.style.opacity = '0';
    form.style.pointerEvents = 'none';
    setTimeout(function() {
      form.style.display = 'none';
      sentBox.style.display = 'flex';
      sentBack.style.display = 'none';
      phraseIndex = 0;
      firstPhraseShown = false;
      runCycle();
    }, 320);

    setTimeout(function() {
      window.open(waUrl, '_blank', 'noopener');
    }, 480);
  });

  function runCycle() {
    typePhrase(phrases[phraseIndex], function() {
      // After first phrase typed, show button
      if (!firstPhraseShown) {
        firstPhraseShown = true;
        sentBack.style.display = 'inline-block';
        sentBack.style.opacity = '0';
        sentBack.style.transition = 'opacity 0.4s';
        setTimeout(function() { sentBack.style.opacity = '1'; }, 10);
      }
      // Pause, then erase, then next phrase
      cycleTimer = setTimeout(function() {
        eraseText(function() {
          phraseIndex = (phraseIndex + 1) % phrases.length;
          cycleTimer = setTimeout(runCycle, 400);
        });
      }, 2400);
    });
  }

  function typePhrase(text, onDone) {
    var i = 0;
    sentTyped.innerHTML = '';
    function tick() {
      if (i < text.length) {
        var ch = text[i++];
        sentTyped.innerHTML += (ch === '\n') ? '<br>' : ch;
        cycleTimer = setTimeout(tick, 38);
      } else {
        if (onDone) onDone();
      }
    }
    tick();
  }

  function eraseText(onDone) {
    // Convert innerHTML to plain chars array (respecting <br>)
    function getRaw() { return sentTyped.innerHTML; }
    function tick() {
      var html = getRaw();
      if (html.length === 0) {
        if (onDone) onDone();
        return;
      }
      // Remove last char or last <br>
      if (html.slice(-4) === '<br>') {
        sentTyped.innerHTML = html.slice(0, -4);
      } else {
        sentTyped.innerHTML = html.slice(0, -1);
      }
      cycleTimer = setTimeout(tick, 22);
    }
    tick();
  }

  sentBack.addEventListener('click', function() {
    // Stop any running cycle
    if (cycleTimer) clearTimeout(cycleTimer);
    sentBox.style.transition = 'opacity 0.3s';
    sentBox.style.opacity = '0';
    setTimeout(function() {
      sentBox.style.display = 'none';
      sentBox.style.opacity = '1';
      sentTyped.innerHTML = '';
      form.reset();
      form.style.display = '';
      form.style.pointerEvents = '';
      form.style.opacity = '0';
      form.style.transition = 'opacity 0.3s ease';
      setTimeout(function() { form.style.opacity = '1'; }, 10);
    }, 300);
  });

  // Copy email to clipboard
  var copyRow = document.getElementById('copy-email-row');
  var copyHint = document.getElementById('copy-email-hint');
  if (copyRow && copyHint) {
    copyRow.addEventListener('click', function() {
      navigator.clipboard.writeText('studio@znatic.my.id').then(function() {
        copyHint.textContent = 'Copied!';
        copyHint.classList.add('copied');
        setTimeout(function() {
          copyHint.classList.remove('copied');
          copyHint.textContent = 'Copy';
        }, 2000);
      });
    });
  }
})();
</script>
