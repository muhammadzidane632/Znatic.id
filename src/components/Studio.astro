---
// Studio / Philosophy Section
---

<section id="studio" class="section-pad studio-section section-dark">
  <div class="container-znatic">

    <div class="studio-layout">

      <!-- Left: editorial text -->
      <div class="studio-editorial reveal">
        <span class="eyebrow">The Studio</span>
        <h2 class="studio-headline">
          <span id="znatic-type"></span><span class="typing-cursor">|</span>
        </h2>
        <div class="studio-rule"></div>
        <p class="studio-quote">
          "We don't just build websites.<br />
          We craft digital presences that last."
        </p>
      </div>

      <!-- Right: philosophy text -->
      <div class="studio-philosophy">

        <div class="philosophy-block reveal" style="transition-delay:80ms">
          <h3 class="phil-heading">Our Philosophy</h3>
          <p class="phil-text">
            ZNATIC was founded on a singular conviction: the intersection of art
            and technology is where the most powerful work lives. We operate as
            a small, dedicated studio — not an agency factory — which means every
            engagement receives our full attention, creativity, and craft.
          </p>
          <p class="phil-text">
            We are obsessive about the details most people never notice:
            the weight of a typeface, the timing of a transition, the breathing
            room of white space. These micro-decisions accumulate into something
            unmistakably refined.
          </p>
        </div>

        <div class="philosophy-values reveal" style="transition-delay:160ms">
          <div class="phil-row">
            <span class="phil-row-num">I.</span>
            <div class="phil-row-body">
              <strong>Craft over volume</strong>
              <p>We take fewer projects to give each one everything it deserves.</p>
            </div>
          </div>
          <div class="phil-row">
            <span class="phil-row-num">II.</span>
            <div class="phil-row-body">
              <strong>Clarity over complexity</strong>
              <p>Simple, purposeful solutions always outperform clever ones.</p>
            </div>
          </div>
          <div class="phil-row">
            <span class="phil-row-num">III.</span>
            <div class="phil-row-body">
              <strong>Longevity over trends</strong>
              <p>We design for timelessness, not for what's trending this quarter.</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* Two-column layout */
  .studio-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 96px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .studio-layout {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }

  /* Editorial left column */
  .studio-editorial {
    position: sticky;
    top: 120px;
  }

  @media (max-width: 900px) {
    .studio-editorial { position: static; }
  }

  .studio-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-top: 20px;
    margin-bottom: 32px;
    min-height: 220px;
  }

  /* Typing animation container */
  .typing-container {
    display: inline-block;
    white-space: pre-wrap;
  }

  .typing-text {
    display: inline;
  }

  .typing-cursor {
    display: inline-block;
    margin-left: 2px;
    animation: blink 0.7s infinite;
    color: currentColor;
    font-weight: 300;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .typing-cursor.active {
    opacity: 1;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .italic-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold);
  }

  .studio-rule {
    width: 40px;
    height: 1px;
    background-color: var(--color-primary);
    margin-bottom: 24px;
    opacity: 0.35;
  }

  .studio-quote {
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.7;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    padding-left: 20px;
  }

  /* Right: philosophy */
  .studio-philosophy {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .phil-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }

  .phil-text {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .phil-text:last-child {
    margin-bottom: 0;
  }

  /* Values — open divider rows */
  .philosophy-values {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border-soft);
  }

  .phil-row {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border-soft);
    transition: background 0.25s var(--ease-apple), padding-left 0.25s var(--ease-apple);
  }

  .phil-row:hover {
    background: rgba(18, 18, 18, 0.6);
    padding-left: 8px;
  }

  .phil-row-num {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.1em;
    flex-shrink: 0;
    width: 28px;
    padding-top: 2px;
    font-style: italic;
    opacity: 0.7;
  }

  .phil-row-body strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 650;
    color: var(--color-text-primary);
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }

  .phil-row-body p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }
</style>

<script is:inline>
(function () {
  var phrases = [
    'Znatic Studio',
    'We believe great\ndesign is\nnever finished.'
  ];
  var idx = 0, pos = 0, erasing = false;

  function render() {
    var el = document.getElementById('znatic-type');
    if (el) el.innerHTML = phrases[idx].substring(0, pos).replace(/\n/g, '<br>');
  }

  function step() {
    var full = phrases[idx].length;
    if (!erasing) {
      pos++;
      render();
      if (pos === full) {
        setTimeout(function () { erasing = true; step(); }, 2400);
      } else {
        setTimeout(step, 60 + Math.random() * 25);
      }
    } else {
      pos--;
      render();
      if (pos === 0) {
        erasing = false;
        idx = (idx + 1) % phrases.length;
        setTimeout(step, 500);
      } else {
        setTimeout(step, 32 + Math.random() * 15);
      }
    }
  }

  // Start setelah GSAP selesai init (delay 2s)
  var cursor = document.querySelector('.typing-cursor');
  setTimeout(function() {
    if (cursor) cursor.classList.add('active');
    step();
  }, 2000);
})();
</script>
