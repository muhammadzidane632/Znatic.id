---
// Services Section — Editorial list layout
---

<section id="services" class="section-pad services-section section-light">
  <div class="container-znatic">

    <!-- Asymmetric header -->
    <div class="svc-header reveal">
      <div class="svc-header-left">
        <span class="eyebrow">What We Do</span>
      </div>
      <div class="svc-header-right">
        <h2 class="svc-heading">
          Services built for<br />
          <em class="italic-accent">ambitious brands</em>
        </h2>
        <p class="svc-intro">
          From concept to deployment — end-to-end digital solutions
          that combine strategic thinking with refined craft.
        </p>
      </div>
    </div>

    <!-- Skeleton overlay -->
    <div class="services-wrapper">
      <div class="svc-skeleton" id="services-skeleton" aria-hidden="true">
        <div class="skeleton skeleton-block" style="height:88px"></div>
        <div class="skeleton skeleton-block" style="height:88px"></div>
        <div class="skeleton skeleton-block" style="height:88px"></div>
        <div class="skeleton skeleton-block" style="height:88px"></div>
      </div>

      <!-- Editorial list -->
      <div class="svc-list reveal-stagger" id="services-content">

        <div class="svc-row">
          <div class="svc-index">
            <span class="svc-num">01</span>
          </div>
          <div class="svc-main">
            <h3 class="svc-title">UI/UX Design</h3>
            <p class="svc-desc">
              Interfaces that feel intuitive and look exceptional. We design systems
              rooted in human behavior and elevated by visual precision.
            </p>
          </div>
          <div class="svc-tags-col">
            <ul class="svc-tags">
              <li>Product Interfaces</li>
              <li>Design Systems</li>
              <li>Prototyping &amp; Testing</li>
            </ul>
          </div>
        </div>

        <div class="svc-row">
          <div class="svc-index">
            <span class="svc-num">02</span>
          </div>
          <div class="svc-main">
            <h3 class="svc-title">Web Development</h3>
            <p class="svc-desc">
              Performant, scalable websites and applications built with modern
              technologies, engineered for speed, reliability, and growth.
            </p>
          </div>
          <div class="svc-tags-col">
            <ul class="svc-tags">
              <li>Frontend Engineering</li>
              <li>Full-Stack Solutions</li>
              <li>Performance Optimization</li>
            </ul>
          </div>
        </div>

        <div class="svc-row">
          <div class="svc-index">
            <span class="svc-num">03</span>
          </div>
          <div class="svc-main">
            <h3 class="svc-title">Product Design</h3>
            <p class="svc-desc">
              From zero to one — we shape digital products with purpose,
              aligning user needs with business objectives at every stage.
            </p>
          </div>
          <div class="svc-tags-col">
            <ul class="svc-tags">
              <li>Product Strategy</li>
              <li>User Research</li>
              <li>End-to-End Delivery</li>
            </ul>
          </div>
        </div>

        <div class="svc-row">
          <div class="svc-index">
            <span class="svc-num">04</span>
          </div>
          <div class="svc-main">
            <h3 class="svc-title">Digital Experience</h3>
            <p class="svc-desc">
              Holistic digital experiences that connect brands to their audiences
              with coherence, emotion, and lasting impression.
            </p>
          </div>
          <div class="svc-tags-col">
            <ul class="svc-tags">
              <li>Brand Experience</li>
              <li>Motion &amp; Interaction</li>
              <li>Digital Strategy</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: #FFFFFF;
    transition: background-color 0.8s ease;
  }

  /* Asymmetric header */
  .svc-header {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 0 64px;
    align-items: end;
    margin-bottom: 72px;
  }

  .svc-header-left {
    padding-bottom: 6px;
  }

  .svc-heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    margin-bottom: 16px;
  }

  .italic-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--color-primary);
  }

  .svc-intro {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 52ch;
  }

  @media (max-width: 768px) {
    .svc-header {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 40px;
    }
  }

  @media (max-width: 580px) {
    .svc-header {
      margin-bottom: 28px;
    }
  }

  /* Wrapper / Skeleton */
  .services-wrapper {
    position: relative;
  }

  .svc-skeleton {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 2;
    pointer-events: none;
  }

  /* Editorial list */
  .svc-list {
    display: flex;
    flex-direction: column;
  }

  .svc-row {
    display: grid;
    grid-template-columns: 88px 1fr 200px;
    gap: 0 48px;
    padding: 48px 0;
    border-bottom: 1px solid var(--color-border-soft);
    align-items: start;
    cursor: pointer;
    position: relative;
    transition: 
      background 0.35s var(--ease-apple), 
      padding-left 0.35s var(--ease-apple),
      transform 0.3s var(--ease-apple);
  }

  .svc-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: var(--color-primary);
    opacity: 0;
    transform: scaleY(0);
    transition: opacity 0.3s var(--ease-apple), transform 0.3s var(--ease-apple);
  }

  .svc-row::after {
    content: '→';
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%) translateX(-10px);
    opacity: 0;
    font-size: 1.5rem;
    color: var(--color-primary);
    transition: opacity 0.3s var(--ease-apple), transform 0.3s var(--ease-apple);
  }

  .svc-list .svc-row:first-child {
    border-top: 1px solid var(--color-border-soft);
  }

  .svc-row:hover {
    padding-left: 16px;
    padding-right: 6px;
    transform: translateX(4px);
  }

  .svc-row:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .svc-row:hover::after {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .svc-num {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    padding-top: 5px;
    font-variant-numeric: tabular-nums;
  }

  .svc-title {
    font-size: clamp(1.375rem, 2.2vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: 14px;
    line-height: 1.1;
    transition: color 0.25s var(--ease-apple);
  }

  .svc-row:hover .svc-title {
    color: var(--color-primary);
  }

  .svc-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.78;
    max-width: 50ch;
  }

  /* Tags column */
  .svc-tags-col {
    padding-top: 5px;
  }

  .svc-tags {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .svc-tags li {
    font-size: 0.775rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    padding-left: 16px;
    position: relative;
    line-height: 1.4;
  }

  .svc-tags li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 1px;
    background: var(--color-border);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .svc-row {
      grid-template-columns: 64px 1fr;
      gap: 0 28px;
    }

    .svc-tags-col {
      grid-column: 2;
      padding-top: 20px;
    }
  }

  @media (max-width: 580px) {
    .svc-row {
      grid-template-columns: 1fr;
      padding: 36px 0;
      gap: 16px;
      cursor: default;
      transition: none;
    }

    .svc-tags-col {
      grid-column: 1;
    }

    .svc-row:hover {
      padding-left: 0;
      padding-right: 0;
      transform: none;
      background: none;
    }

    .svc-row:hover .svc-title {
      color: var(--color-text-primary);
    }

    .svc-row::before,
    .svc-row:hover::before,
    .svc-row::after,
    .svc-row:hover::after {
      display: none;
    }
  }
</style>

